# Copy this file to ".env" and fill in real values. Never commit ".env".

# Postgres connection string (Neon). Looks like:
# postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign login tokens (JWT). Use a long random string.
JWT_SECRET=

# Google OAuth client ID (from Google Cloud console) for "Continue with Google".
GOOGLE_CLIENT_ID=

# Google Gemini API key, used by the AI Study Tutor.
GEMINI_API_KEY=

# Port the backend listens on (defaults to 3000 if unset).
PORT=3000

# Production only: comma-separated list of allowed front-end origins, e.g.
# https://studyusict.com,https://www.studyusict.com
# Leave blank in local development to allow any origin.
CORS_ORIGIN=

# Production only: set to 1 when running behind a hosting proxy (Render,
# Railway, etc.) so rate limiting reads the real client IP. Leave unset locally.
TRUST_PROXY=
